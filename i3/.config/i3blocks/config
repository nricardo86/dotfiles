command=/usr/share/i3blocks/$BLOCK_NAME
separator_block_width=40
markup=none

[cpu_usage]
command=~/.config/i3blocks/cpu_usage
label=cpu 
label=   
interval=5

[memory]
command=free -mh | grep Mem | awk '{print $7}'
label=mem  
label=    
interval=30

[bandwidth3]
command=~/.config/i3blocks/bandwidth3
interval=persist

[wifi]
command=~/.config/i3blocks/wifi
label=wifi
label=  
interval=30

[wg]
command=~/.config/i3blocks/wg
interval=5

[temperature]
command=sensors | grep "Package id 0" | awk '{print $4}' | cut -d'+' -f2
label=temp 
label= 
interval=5

[volume]
command=~/.config/i3blocks/volume
label=Vol:
label= 
interval=1

[brightness]
command=~/.config/i3blocks/brightness
label=Brigthness:
label=󰃞  
interval=1

[battery]
command=~/.config/i3blocks/battery
label=Bat:
label=󰂄 
interval=30

[time]
color=#FFFF00
command=date '+   %d/%m/%Y  %H:%M:%S'
interval=1 
