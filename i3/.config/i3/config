set $borda 4 
font Pango:JetBrainsMono 14
new_window pixel $borda
default_border pixel $borda
default_floating_border pixel $borda
hide_edge_borders none
smart_borders on
gaps inner 0
smart_gaps off

popup_during_fullscreen smart

default_orientation auto

floating_modifier Mod1
for_window [class="pavucontrol"] floating enable
for_window [class="Tor Browser"] floating enable
for_window [class="electrum"] floating enable
for_window [class="FeatherWallet"] floating enable
for_window [class="Virt-manager"] floating enable
for_window [class="KiCad"] floating enable
for_window [class="Lxappearance"] floating enable
for_window [class="qt5ct"] floating enable
for_window [class="qt6ct"] floating enable
for_window [class="localsend_app"] floating enable

bindsym Mod4+o exec libreoffice --nolockcheck
bindsym Mod4+p exec gtk-launch ranger
bindsym Mod4+b exec brave --profile-directory="Default"
bindsym Mod4+t exec alacritty
# bindsym Mod4+i exec bash -c "$HOME/.local/bin/LocalSend-1.13.1-linux-x86-64.AppImage"
# bindsym Mod4+m exec bash -c "$HOME/.bin/touchPad.sh"
bindsym Mod4+y exec bash -c "$HOME/.bin/disp.sh -d"
bindsym Mod4+u exec bash -c "$HOME/.bin/xlockidle.sh -l"
bindsym Mod4+Return exec i3-dmenu-desktop --dmenu="dmenu -i -fn 'JetBrainsMono-14' -nb '#000' -nf '#FFF' -sb '#10f'"
bindsym Mod4+shift+Return exec dmenu_run -i -fn 'JetBrainsMono-14' -sb '#040' -nf '#FFF' -nb '#000'
bindsym Print exec flameshot gui
bindsym XF86PowerOff exec bash -c "$HOME/.bin/lockscreen.sh"
bindsym Mod4+Delete exec bash -c "$HOME/.bin/lockscreen.sh"
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym shift+XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +25%
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -5% 
bindsym shift+XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -25% 
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle 
bindsym XF86AudioMicMute exec --no-startup-id amixer -D pulse sset Capture toggle
#bindsym XF86AudioPlay exec --no-startup-id 
bindsym XF86MonBrightnessDown exec bash -c "$HOME/.bin/disp.sh -b -"
bindsym XF86MonBrightnessUp exec bash -c "$HOME/.bin/disp.sh -b +"

bindsym Mod4+h focus left
bindsym Mod4+j focus down
bindsym Mod4+k focus up
bindsym Mod4+l focus right

bindsym Mod4+Shift+h move left
bindsym Mod4+Shift+j move down
bindsym Mod4+Shift+k move up
bindsym Mod4+Shift+l move right

focus_follows_mouse no
focus_on_window_activation smart
focus_wrapping force

bindsym Mod4+shift+q kill
bindsym Mod4+s focus parent
bindsym Mod4+d focus child
bindsym Mod4+e layout toggle split
bindsym Mod4+f fullscreen toggle
bindsym Mod4+g focus mode_toggle
bindsym Mod4+shift+g floating toggle

workspace_auto_back_and_forth yes

#assign [class="Alacritty"] $ws3
#assign [class="libreoffice"] $ws4

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"

set $mon1 DP-3
set $mon2 eDP-1

workspace $ws1 output $mon1
workspace $ws2 output $mon1
workspace $ws3 output $mon1
workspace $ws4 output $mon1
workspace $ws5 output $mon1
workspace $ws6 output $mon2
workspace $ws7 output $mon2
workspace $ws8 output $mon2

bindsym Mod1+a workspace $ws1
bindsym Mod1+s workspace $ws2
bindsym Mod1+d workspace $ws3
bindsym Mod1+f workspace $ws4
bindsym Mod1+g workspace $ws5
bindsym Mod1+h workspace $ws6
bindsym Mod1+j workspace $ws7
bindsym Mod1+k workspace $ws8

bindsym Mod1+shift+a move container to workspace $ws1; workspace $ws1
bindsym Mod1+shift+s move container to workspace $ws2; workspace $ws2
bindsym Mod1+shift+d move container to workspace $ws3; workspace $ws3
bindsym Mod1+shift+f move container to workspace $ws4; workspace $ws4
bindsym Mod1+shift+g move container to workspace $ws5; workspace $ws5
bindsym Mod1+shift+h move container to workspace $ws6; workspace $ws6
bindsym Mod1+shift+j move container to workspace $ws7; workspace $ws7
bindsym Mod1+shift+k move container to workspace $ws8; workspace $ws8

bindsym Mod4+shift+c reload
bindsym Mod4+shift+r restart
bindsym Mod4+shift+x exec bash -c "$HOME/.bin/logout.sh"

mode "resize" {
        bindsym h resize shrink width 2 px or 2 ppt
        bindsym shift+h resize shrink width 20 px or 20 ppt
        bindsym l resize grow width 2 px or 2 ppt
        bindsym shift+l resize grow width 20 px or 20 ppt
        bindsym k resize shrink height 2 px or 2 ppt
        bindsym shift+k resize shrink height 20 px or 20 ppt
        bindsym j resize grow height 2 px or 2 ppt
        bindsym shift+j resize grow, height 20 px or 20 ppt

        bindsym Escape mode "default"
}
bindsym Mod4+r mode "resize"

# class                 border  bground text    indicator child_border
client.focused          #FF9900 #FF9900 #F8F8F2 #FF9900   #FF9900
client.focused_inactive #44475A #44475A #F8F8F2 #44475A   #44475A
client.unfocused        #282A36 #282A36 #BFBFBF #282A36   #282A36
client.urgent           #FF0000 #FF0000 #F8F8F2 #FF0000   #FF0000
client.placeholder      #282A36 #282A36 #F8F8F2 #282A36   #282A36
client.background       #F8F8F2

bar {
  font pango:JetBrainsMono 14
  padding 2px 10px
  separator_symbol | 
  tray_padding 10
  position top
  #output primary
  workspace_min_width 80
  #bindsym button1 nop
  colors {
    background #000000
    statusline #FFFFFF
    separator  #FFFFFF

    focused_workspace  #FFFFFF #000000 #1CB055
    active_workspace   #000000 #000000 #F8F8F2
    inactive_workspace #000000 #000000 #BFBFBF
    urgent_workspace   #FF0000 #FF0000 #F8F8F2
    binding_mode       #FF0000 #FF0000 #F8F8F2
  }
  status_command i3blocks
}

exec_always --no-startup-id rm $HOME/.disp-day; rm $HOME/.xidleoff
exec_always --no-startup-id bash -c "$HOME/.bin/disp.sh -i"; feh --no-fehbg --bg-scale --randomize $HOME/.wallpaper/
# exec_always --no-startup-id bash -c "$HOME/.bin/synaptics_config.sh"

exec_always --no-startup-id killall xbanish; xbanish -t 5
exec_always --no-startup-id killall dunst; dunst
exec_always --no-startup-id killall autotiling; autotiling
exec_always --no-startup-id killall picom; picom -Cb
