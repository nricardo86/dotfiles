# Aliases
alias ls='exa --icons'
alias l='exa --icons -lg'
alias la='exa --icons -lag'
alias rsync='rsync -avhP'
alias cal='ncal -C'
alias dd='dd status=progress'
alias free='free -mh'
alias lp='lp -o fit-to-page'
alias df='df -hT'
alias mkdir='mkdir -pv'
alias bat="batcat"
alias fmu="fusermount -u"
alias um="udisksctl mount -b"
alias uu="udisksctl unmount -b"
alias wq="sudo wg-quick"
alias tat="tmux at -t"
alias za="zathura"
alias nmc="nmcli --ask"
alias s="du -hcs"

if [ -n "$KITTY_PID" ]; then
    abbr e icat 2&>/dev/null 1&>/dev/null
    abbr e i 2&>/dev/null 1&>/dev/null
    abbr a icat="kitty +kitten icat" 1&>/dev/null 2&>/dev/null
    abbr a i="kitty +kitten icat" 1&>/dev/null 2&>/dev/null
else
    abbr e icat 2&>/dev/null 1&>/dev/null
    abbr e i 2&>/dev/null 1&>/dev/null 
    abbr a i="swayimg" 1&>/dev/null 2&>/dev/null
fi
