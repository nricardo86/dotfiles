# Aliases
alias ls='exa --icons'
alias l='exa --icons -lg'
alias la='exa --icons -lag'
alias rsync='rsync -avhP'
alias cal='ncal -C'
alias dd='dd status=progress'
alias free='free -mh'
alias lp='lp -o fit-to-page'
alias lpbln="ssh bln lp -o fit-to-page"
alias df='df -hT'
alias mkdir='mkdir -pv'
alias feh='feh --scale-down'
alias apti="sudo apt install"
alias aptu="sudo apt update && sudo apt upgrade"
alias aptr="sudo apt autoremove --purge $(deborphan)"
alias b="batcat"
alias fmu="fusermount -u"
alias um="udisksctl mount -b"
alias uu="udisksctl unmount -b"
alias wq="sudo wg-quick"
alias tat="tmux at -t"
alias za="zathura"
alias nmc="nmcli --ask"
alias s="du -hcs"
