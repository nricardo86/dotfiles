#!/usr/bin/env bash
MTX="/usr/local/bin/mtx"
MT="/usr/bin/mt"
SG="/usr/bin/sg_read_attr"
TAPE=$(lsscsi | grep HH6 | awk '{print $6}')
TAPE=$(echo "/dev/nst${TAPE: -1:1}")
BS=512
TAPELIBRARY=$(lsscsi -g | grep mediumx | awk '{print $7}')
TAPEDRIVE=${TAPE: -1:1}

function usage {
    echo "$(basename $0) [options] directory slot [nslots]"
    echo "options:"
    echo "[-s] Statistics only"
    echo "[-t <Tape dev>] default $TAPE"
    echo "[-b <n blocksize>] \"n*512bytes\" default $((BS * 512 / 1024))kb"
    exit 1
}

while getopts "b:t:sf" o; do
    case "${o}" in
    s) STATS_ONLY=TRUE ;;
    t)
        TAPE=$OPTARG
        TAPEDRIVE=${TAPE: -1:1}
        ;;
    b) BS=$OPTARG ;;
    f) FULL=TRUE ;;
    *) usage ;;
    esac
done
shift $((OPTIND - 1))

function loadTape {
    $MTX -f $TAPELIBRARY load $SLOT $TAPEDRIVE
}

function unloadTape {
    $MTX -f $TAPELIBRARY unload $SLOT $TAPEDRIVE
}

function eraseTape {
    echo "Erasing Tape..."
    $MT -f $TAPE erase 0
}

function find_select {
    if [[ -e $DIR/lastTapeBackup ]]; then
        local lastBackup=$(stat -c %Y $DIR/lastTapeBackup)
        local now=$(date +%s)
        local nDays=$(((lastBackup - now) / 86400))
        DAYS=("-mtime")
        DAYS+=($nDays)
    fi
    find $DIR -type f ${DAYS[@]} $@
}

function tar_cmd {
    tar --format=pax -T - -cf - 2>/dev/null
}

function sizeRemain {
    sudo $SG $TAPE -f 0x0 2>/dev/null | awk '{print $6}'
}

function mbuffer_send {
    mbuffer -q \
        -s $((BS * 512)) \
        -m 10% \
        -l /tmp/mbuffer_dir2tape-$(date +%s).log \
        -A "((SLOT++));[[ $SLOT -lt $NSLOTS ]] && $MTX -f $TAPELIBRARY next $TAPEDRIVE || exit 1" \
        -o $TAPE 2>/dev/null
}

function sizeFiles {
    find_select "-printf %s\n" | awk '{sum += $1} END {print sum}'
}

function main {
    DIR=$1
    SLOT=$2
    NSLOTS=${3:-1}
    NSLOTS=$((SLOT + NSLOTS))

    if [[ -n $STATS_ONLY ]]; then
        if [[ -e $DIR/lastTapeBackup ]]; then
            echo "Partial Backup"
            echo "Last Backup: $(stat -c %y $DIR/lastTapeBackup)"
        else
            echo "Full Backup"
        fi
        echo "Processing sizes..."
        local size=$(sizeFiles)
        echo "Size for next backup: $((size / 1048576))MiB"
        return 0
    fi

    [[ -z $SLOT ]] && usage

    if [[ ! -d $DIR ]]; then
        echo directory invalid
        exit 1
    fi
    echo "Directory: $DIR"

    echo "Tape dev: $TAPE"
    echo "Blocksize: $((BS * 512 / 1024))kb"
    echo "Tape Library dev: $TAPELIBRARY"
    echo "Slot TapeLibrary: $SLOT"

    loadTape
    [[ -z $FULL ]] && touch $DIR/lastTapeBackup
    if [[ ! -e $DIR/lastTapeBackup || -n $FULL ]]; then
        echo "Full Backup"
        eraseTape
        find_select "-print0" | tar_cmd | mbuffer_send
        unloadTape
        return 0
    fi
    while [[ "$(($(sizeFiles) / 1048576))" -gt "$(sizeRemain)" ]]; do
        $MTX -f $TAPELIBRARY next $TAPEDRIVE
        ((SLOT++))
        if [[ $SLOT -ge $NSLOTS ]]; then
            echo "Last Tape full"
            unloadTape
            exit 2
        fi
    done
    echo "Partial Backup"
    find_select "-print0" | tar_cmd | mbuffer_send
    unloadTape
}

main $@
