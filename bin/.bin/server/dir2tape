#!/usr/bin/env bash
MTX="/usr/local/bin/mtx"
MT="/usr/bin/mt"
SG="/usr/bin/sg_read_attr"
TAPE=$(lsscsi | grep HH6 | awk '{print $6}')
TAPE=$(echo "/dev/nst${TAPE: -1:1}")
BS=512
TAPELIBRARY=$(lsscsi -g | grep mediumx | awk '{print $7}')
TAPEDRIVE=${TAPE: -1:1}

function usage {
    echo "$(basename $0) [options] directory slot [nslots]"
    echo "options:"
    echo "[-s] Statistics only"
    echo "[-t <Tape dev>] default $TAPE"
    echo "[-b <n blocksize>] \"n*512bytes\" default $((BS * 512 / 1024))kb"
    exit 1
}

while getopts "b:t:sf" o; do
    case "${o}" in
    s) STATS_ONLY=TRUE ;;
    t)
        TAPE=$OPTARG
        TAPEDRIVE=${TAPE: -1:1}
        ;;
    b) BS=$OPTARG ;;
    f) FULL=TRUE ;;
    *) usage ;;
    esac
done
shift $((OPTIND - 1))

function findEOM {
    echo "Finding EOM..."
    local count=3
    while true; do
        $MT -f "${TAPE}" eom 2>/dev/null && break
        if [[ "${count}" -eq "0" ]]; then
            echo "EOM not found!"
            return 1
        fi
        ((count--))
        tapeRewind
    done
    echo "EOM found!"
    FILES_ONTAPE=$(($FILES_ONTAPE + $($MT -f "${TAPE}" status | grep 'file number' | awk '{print $4}')))
    echo "Files on Tape: $FILES_ONTAPE"
}

function unloadTape {
    local driveStatus=$($MTX -f ${TAPELIBRARY} status | grep "Data Transfer Element ${TAPEDRIVE}:")
    local driveLoaded=$(echo $driveStatus | awk -F ':' '{print $2}')
    [[ ${driveLoaded} == "Empty" ]] && return 0
    local storageSlot=$(echo $driveStatus | awk '{print $7}')
    $MTX -f $TAPELIBRARY unload $storageSlot $TAPEDRIVE
}

function loadTape {
    unloadTape
    $MTX -f $TAPELIBRARY load $SLOT $TAPEDRIVE
}

function tapeRewind {
    echo "Rewinding Tape..."
    $MT -f $TAPE rewind
}

function eraseTape {
    tapeRewind
    echo "Erasing Tape..."
    $MT -f $TAPE erase 0
}

function sizeRemain {
    sudo $SG $TAPE -f 0x0 2>/dev/null | awk '{print $6}'
}

function find_select {
    if [[ -e $DIR/lastTapeBackup ]]; then
        local lastBackup=$(stat -c %Y $DIR/lastTapeBackup)
        local now=$(date +%s)
        local nDays=$(((lastBackup - now) / 86400))
        DAYS=("-mtime")
        DAYS+=($nDays)
    fi
    [[ -n $FULL ]] && unset DAYS
    find $DIR -type f ${DAYS[@]} $@
}

function tar_cmd {
    tar --format=pax -T - -cf - 2>/dev/null
}

function mbuffer_send {
    mbuffer \
        -s $((BS * 512)) \
        -m 10% \
        -A "$MTX -f $TAPELIBRARY next $TAPEDRIVE" \
        -o $TAPE 2>/dev/null
}

function sizeFiles {
    find_select "-printf %s\n" | awk '{sum += $1} END {print sum}'
}

function showFilesSize {
    local size_files_mb=$(($(sizeFiles) / 1048576))
    [[ "$size_files_mb" -ge 10000 ]] && echo "Files to backup: $((size_files_mb / 1024))GiB" || echo "Files to backup: ${size_files_mb}MiB"
}

function showRemainSize {
    local size_remain_mb=$(sizeRemain)
    [[ "$size_remain_mb" -ge 10000 ]] && echo "Remain space on tape: $((size_remain_mb / 1024))GiB" || echo "Remain space on tape: ${size_remain_mb}MiB"
}

function send2tape {
    showFilesSize
    showRemainSize
    echo "Sending to Tape.."
    touch $DIR/lastTapeBackup
    find_select "-print0" | tar_cmd | mbuffer_send
}

function fullBackup {
    echo "Full Backup"
    eraseTape
    send2tape
}

function partialBackup {
    echo "Partial Backup"
    send2tape
}

function main {
    DIR=$1
    SLOT=$2
    NSLOTS=${3:-0}
    NSLOTS=$((SLOT + NSLOTS))

    if [[ ! -d $DIR ]]; then
        echo directory invalid
        exit 1
    fi

    if [[ -n $STATS_ONLY ]]; then
        if [[ -z $FULL && -e $DIR/lastTapeBackup ]]; then
            echo "Partial Backup"
            echo "Last Backup: $(stat -c %y $DIR/lastTapeBackup)"
        else
            echo "Full Backup"
        fi
        echo -ne "Processing sizes...\r"
        showFilesSize
        exit 0
    fi

    [[ -z $SLOT ]] && usage

    echo "Directory: $DIR"
    echo "Tape dev: $TAPE"
    echo "Blocksize: $((BS * 512 / 1024))kb"
    echo "Tape Library dev: $TAPELIBRARY"
    echo "TapeLibrary Storage: $SLOT"

    echo "Begin of backup - $(date --utc +%Y/%m/%d-%H:%M)"

    loadTape

    if [[ ! -e $DIR/lastTapeBackup || -n $FULL ]]; then
        fullBackup
    else
        while [[ "$(($(sizeFiles) / 1048576))" -gt "$(sizeRemain)" ]]; do
            ((SLOT++))
            if [[ $SLOT -eq $NSLOTS ]]; then
                echo "Last Tape full"
                unloadTape
                exit 2
            fi
            showFilesSize
            showRemainSize
            $MTX -f $TAPELIBRARY next $TAPEDRIVE
        done
        findEOM
        partialBackup
    fi

    showRemainSize
    unloadTape

    echo "End of backup - $(date --utc +%Y/%m/%d-%H:%M)"
}

main $@
