#!/usr/bin/env bash
MTX="/usr/local/bin/mtx"
MT="/usr/bin/mt"
SG="/usr/bin/sg_read_attr"
LSSCSI="/usr/bin/lsscsi"
DRIVE="J451"
TAPE=$($LSSCSI | grep $DRIVE | awk '{print $6}')
TAPE=$(echo "/dev/nst${TAPE: -1:1}")
BS=512
TAPELIBRARY=$($LSSCSI -g | grep mediumx | awk '{print $7}')
TAPEDRIVE=${TAPE: -1:1}
FILES_ONTAPE=0

function usage {
    echo "usage: $(basename $0) [options] dataset init_slot [n_slots] [prefix]"
    echo "options:"
    echo "[-r] Don't create new snapshot, only backup existing ones"
    echo "[-b '$BS']"
    echo "[-t '$TAPE'] "
    exit 1
}

while getopts "rb:t:" o; do
    case "${o}" in
    r) RECURSIVE_ONLY=true ;;
    b) BS="${OPTARG}" ;;
    t)
        TAPE="${OPTARG}"
        TAPEDRIVE=${TAPE: -1:1}
        ;;
    *) usage ;;
    esac
done
shift $((OPTIND - 1))

function findEOM {
    echo "Finding EOM..."
    local count=3
    while true; do
        $MT -f "${TAPE}" eom 2>/dev/null && break
        if [[ "${count}" -eq "0" ]]; then
            echo "EOM not found!"
            return 1
        fi
        ((count--))
        tapeRewind
    done
    echo "EOM found!"
    FILES_ONTAPE=$(($FILES_ONTAPE + $($MT -f "${TAPE}" status | grep 'file number' | awk '{print $4}')))
    echo "Files on Tape: $FILES_ONTAPE"
}

function tapeSerial {
    local tape_serial=$(sudo $SG "${TAPE}" -f 0x401 2>/dev/null | awk '{print $4}')
    echo "Tape serial: ${tape_serial}"
}

function tapeBarcode {
    local driveStatus=$($MTX -f $TAPELIBRARY status | grep "Data Transfer Element ${TAPEDRIVE}:")
    local barcode=$(echo $driveStatus | awk '{print $10}')
    echo "Tape barcode: $barcode"
}

function unloadTape {
    local driveStatus=$($MTX -f ${TAPELIBRARY} status | grep "Data Transfer Element ${TAPEDRIVE}:")
    local driveLoaded=$(echo $driveStatus | awk -F ':' '{print $2}')
    [[ ${driveLoaded} == "Empty" ]] && return 0
    local storageSlot=$(echo $driveStatus | awk '{print $7}')
    $MTX -f $TAPELIBRARY unload $storageSlot $TAPEDRIVE
}

function loadTape {
    unloadTape
    $MTX -f $TAPELIBRARY load $1 $TAPEDRIVE
    tapeBarcode
    tapeSerial
    findEOM || return $?
}

function loadNextTape {
    $MTX -f $TAPELIBRARY next $TAPEDRIVE
    tapeBarcode
    tapeSerial
    findEOM || return $?
}

function tapeRewind {
    echo "Rewinding tape!"
    $MT -f "$TAPE" rewind || return $?
}

function checkSize {
    local snap_size=$(zfs send -Pnwc $1 2>/dev/null | tail -1 | awk '{print $2}') || return $?
    local snap_size_mb=$((snap_size / 1048576))
    local size_remain_mb=$(sudo $SG "${TAPE}" -f 0x0 2>/dev/null | awk '{print $6}' | bc) || return $?
    [[ $snap_size_mb -ge 10000 ]] && echo "Snapshot size: $((snap_size_mb / 1024))GiB" || echo "Snapshot size: ${snap_size_mb}MiB"
    [[ $size_remain_mb -ge 10000 ]] && echo "Tape remain size: $((size_remain_mb / 1024))GiB" || echo "Tape remain size: ${size_remain_mb}MiB"

    [[ "${size_remain_mb}" -ge "((snap_size_mb))" ]] && return $? || echo "Insuficient remain space on tape"
    return 102
}

function sizeRemain {
    local size_remain_mb=$(sudo $SG "${TAPE}" -f 0x0 2>/dev/null | awk '{print $6}') || return $?
    [[ "$size_remain_mb" -ge 10000 ]] && echo "Remain space on tape: $((size_remain_mb / 1024))GiB" || echo "Remain space on tape: ${size_remain_mb}MiB"
}

function destroySnap {
    echo "Destroying $1"
    zfs destroy "$1" &>/dev/null
}

function send2tape {
    zfs send -wc $1 | mbuffer \
        -m 10% \
        -s $((BS * 512)) \
        -A "$MTX -f $TAPELIBRARY next $TAPEDRIVE" \
        -o $TAPE 2>/dev/null
}

function firstSnapshot {
    tapeRewind
    local snap_init=$(zfs list -t snapshot $1 -H | grep $2 | head -n1 | awk '{print $1}')
    if [[ -z $snap_init ]]; then
        zfs snapshot -r "${1}@${2}-$(date --utc +%Y%m%d-%H%M)" || return $?
        local snap_init=$(zfs list -t snapshot $1 -H | grep $2 | head -n1 | awk '{print $1}')
        echo "Creating snapshot: $snap_init"
        local created_now=true
    fi

    echo "Full Backup"
    echo "Sending first snapshot: ${snap_init}"
    checkSize "-R ${snap_init}"
    send2tape "-R ${snap_init}"
    if [[ ! $? -eq 0 ]]; then
        [[ -n $created_now ]] && destroySnap $snap_init
        return 1
    fi
    FILES_ONTAPE=1
}

function recursiveSend {
    local count=0
    local snapshots=()
    for i in $(zfs list -t snapshot $1 -H -o name | grep $2); do
        snapshots+=("$i")
    done

    snaps=${#snapshots[@]}
    count=$(("${#snapshots[@]}" - "${FILES_ONTAPE}" + 1))
    echo "Snapshots count: $snaps"
    echo "Snapshots on Tape: $FILES_ONTAPE"
    while [ "${count}" -gt "1" ]; do
        local snap_from="${snapshots[((snaps - count))]}"
        local snap_to="${snapshots[((snaps - ((count - 1))))]}"

        echo "Sending incremental snapshot from ${snap_from} to ${snap_to}"
        checkSize "-I ${snap_from} ${snap_to}"
        while [[ ! $? -eq 0 ]]; do
            loadNextTape
            ((SLOT++))
            if [[ $SLOT -ge $NSLOTS ]]; then
                echo "Last Tape full"
                unloadTape
                exit 1
            fi
            count=$(("${#snapshots[@]}" - "${FILES_ONTAPE}" + 1))
            checkSize "-RI ${last_snapshot} ${now_snapshot}"
        done
        send2tape "-RI ${snap_from} ${snap_to}" || return $?
        ((count--))
    done
}

function snapshot {
    local last_snapshot=$(zfs list -t snapshot -H -o name $1 | grep $2 | tail -1)
    zfs snapshot -r "${1}@${2}-$(date --utc +%Y%m%d-%H%M)" || return $?
    local now_snapshot=$(zfs list -t snapshot -H -o name $1 | grep $2 | tail -1)

    echo "Creating snapshot: $now_snapshot"
    echo "Sending incremental snapshot from ${last_snapshot} to ${now_snapshot}"
    checkSize "-RI ${last_snapshot} ${now_snapshot}"
    while [[ ! $? -eq 0 ]]; do
        loadNextTape
        ((SLOT++))
        if [[ $SLOT -eq $NSLOTS ]]; then
            echo "Last Tape full"
            unloadTape
            exit 1
        fi
        checkSize "-RI ${last_snapshot} ${now_snapshot}"
    done
    send2tape "-RI ${last_snapshot} ${now_snapshot}"
    if [[ ! $? -eq 0 ]]; then
        destroySnap $now_snapshot
        return 1
    fi
}

function main {
    SLOT=${2}
    NSLOTS=${3:-1}
    local ds=${1}
    local prefix="${4:-tapebkp}"

    [[ -z "${ds}" || -z "${SLOT}" ]] && usage
    NSLOTS=$((SLOT + NSLOTS))

    zfs list -H -o name ${ds} >/dev/null || exit $?

    echo "TapeLibrary: ${TAPELIBRARY}"
    echo "Library Drive: ${TAPEDRIVE}"
    echo "Tape Drive: ${TAPE}"
    echo "Block Size: $((BS * 512 / 1024))k"
    echo "Storage Slot: ${SLOT}"
    echo "Dataset: ${ds}"
    echo "Prefix: ${prefix}"
    echo "Begin of backup - $(date --utc +%Y/%m/%d-%H:%M)"
    [[ -n $RECURSIVE_ONLY ]] && echo "Recursive Snapshot Send Only, no new snapshot"

    loadTape $SLOT || exit $?

    if [[ "${FILES_ONTAPE}" -eq 0 ]]; then
        firstSnapshot "${ds}" "${prefix}" || exit $?
    fi

    recursiveSend "${ds}" "${prefix}" || exit $?

    if [[ -z $RECURSIVE_ONLY ]]; then
        snapshot "${ds}" "${prefix}" || exit $?
    fi

    sizeRemain
    unloadTape

    echo "End of backup - $(date --utc +%Y/%m/%d-%H:%M)"
}

main $@
