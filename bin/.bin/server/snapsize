#!/usr/bin/env bash
if [ -z $1 ]; then
    echo "missing pool/dataset"
    exit 1
fi
repo=$1
filter=$2

list=$(zfs list -t snapshot -H -o name ${repo}) || exit $?

for i in ${list[@]}; do
    [[ "$i" == *"${filter}"* ]] && arr+=($i)
done

firstsizes=$(zfs send -Pnwc ${arr[0]} | tail -1 | awk '{print $2}')
firstsizes_mb=$((firstsizes / 1048576))
echo -n "initial snapshot ${arr[0]}: "
if [[ $firstsizes_mb -gt 10000 ]]; then
    firstsizes_gb=$((firstsizes_mb / 1024))
    echo "${firstsizes_gb}GiB"
else
    echo "${firstsizes_mb}MiB"
fi

for ((i = 0; i < ${#arr[@]} - 1; i++)); do
    sizes=$(zfs send -PnwcI ${arr[$i]} ${arr[(($i + 1))]} | tail -1 | awk '{print $2}')
    sizes_mb=$((sizes / 1048576))
    if [[ $sizes_mb -gt 10000 ]]; then
        sizes_gb=$((sizes_mb / 1024))
        echo "inc from ${arr[$i]} to ${arr[(($i + 1))]}: ${sizes_gb}GiB"
    else
        echo "inc from ${arr[$i]} to ${arr[(($i + 1))]}: ${sizes_mb}MiB"
    fi
done

lastsizes=$(zfs send -PnwcR ${arr[-1]} 2>/dev/null | tail -1 | awk '{print $2}')
lastsizes_mb=$((lastsizes / 1048576))
lastsizes_gb=$(echo "scale=2;${lastsizes_mb} / 1024" | bc)
echo "Total size ${1}: ${lastsizes_mb}MiB / ${lastsizes_gb}GiB"
echo "Count snapshots: ${#arr[@]}"
